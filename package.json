{
    "name": "watchhive-server",
    "version": "1.0.0",
    "description": "Backend API for WatchHive - Social Platform for Movie Enthusiasts",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "test:watch": "jest --watch",
        "lint": "eslint src --ext .ts"
    },
    "keywords": [
        "watchhive",
        "movies",
        "social",
        "api"
    ],
    "author": "Aditya Dasamantharao",
    "license": "MIT",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1000.0",
        "@aws-sdk/s3-request-presigner": "^3.1004.0",
        "axios": "^1.13.4",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "drizzle-orm": "^0.45.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "google-auth-library": "^10.5.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^2.0.2",
        "multer-s3": "^3.0.1",
        "pg": "^8.19.0",
        "postgres": "^3.4.8",
        "redis": "^4.6.12",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^2.0.0",
        "@types/multer-s3": "^3.0.3",
        "@types/node": "^20.11.0",
        "@types/pg": "^8.18.0",
        "@types/supertest": "^7.2.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "@typescript-eslint/eslint-plugin": "^6.18.1",
        "@typescript-eslint/parser": "^6.18.1",
        "drizzle-kit": "^0.31.9",
        "esbuild": "^0.27.3",
        "eslint": "^8.56.0",
        "jest": "^30.2.0",
        "nodemon": "^3.0.2",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    }
}